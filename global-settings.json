{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'node \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "theme": "dark-daltonism",
  "teammateMode": "tmux",
  "dangerouslySkipPermissions": true,
  "permissions": {
    "allow": [
      "Bash(yarn lint)",
      "Bash(yarn lint:fix)",
      "Bash(yarn typescript)",
      "Bash(yarn test)",
      "Bash(yarn test:ci)",
      "Bash(yarn test:coverage)",
      "Bash(yarn start)",
      "Bash(yarn start:storybook)",
      "Bash(yarn storybook-generate)",
      "Bash(yarn prettier)",
      "Bash(yarn podinstall)",
      "Bash(yarn clean:build)",
      "Bash(yarn)",
      "Bash(android)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.test)",
      "Read(./.env.test.local)"
    ]
  }
}
